{
  "expo": {
    "name": "Sport Trippin",
    "slug": "sport-trippin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#06060f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sporttrippin.app",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Sport Trippin uses your location to show nearby live games."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06060f"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.sporttrippin.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Sport Trippin uses your location to show nearby live games."
        }
      ]
    ]
  }
}